{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locationiq.local/schemas/interpretive-location-report.v4.json",
  "title": "LocationIQ Reader-First Location Report",
  "description": "Purpose-aware location understanding report. This schema excludes final verdicts, investment advice, proceed/avoid labels, single overall scores, and user-facing source-quality badges.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "reader_summary",
    "purpose_lens",
    "exact_pin",
    "multi_anchor_story",
    "catchment_and_reach",
    "arrival_reality",
    "key_numbers",
    "competition_and_pricing",
    "spend_and_convenience",
    "locality_conditions",
    "visual_evidence_pack",
    "field_verification_plan",
    "source_notes"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_id",
        "generated_at",
        "location_input",
        "selected_pin",
        "purpose_category",
        "sub_purpose",
        "report_mode"
      ],
      "properties": {
        "report_id": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "report_mode": {
          "type": "string",
          "const": "reader_first_location_intelligence"
        },
        "location_input": { "type": "string" },
        "selected_pin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["latitude", "longitude"],
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address_text": { "type": "string" },
            "plus_code": { "type": "string" },
            "locality": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "pin_code": { "type": "string" },
            "geocode_quality_note": { "type": "string" }
          }
        },
        "purpose_category": { "type": "string" },
        "sub_purpose": { "type": "string" },
        "selected_context": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "array", "object", "null"]
          }
        },
        "data_coverage_note": {
          "type": "string",
          "description": "Plain-language description of coverage, freshness, and important gaps."
        }
      }
    },
    "reader_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "summary", "what_looks_useful", "what_can_create_friction", "what_to_verify"],
      "properties": {
        "headline": { "type": "string" },
        "summary": { "type": "string" },
        "what_looks_useful": {
          "type": "array",
          "items": { "$ref": "#/$defs/reader_point" }
        },
        "what_can_create_friction": {
          "type": "array",
          "items": { "$ref": "#/$defs/reader_point" }
        },
        "what_to_verify": {
          "type": "array",
          "items": { "$ref": "#/$defs/reader_point" }
        }
      }
    },
    "purpose_lens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["understanding_question", "what_matters", "excluded_or_not_claimed"],
      "properties": {
        "understanding_question": { "type": "string" },
        "what_matters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded_or_not_claimed": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "exact_pin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pin_read", "nearest_poi_policy", "plot_visualization", "not_claimed"],
      "properties": {
        "pin_read": { "type": "string" },
        "nearest_poi_policy": { "type": "string" },
        "plot_visualization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["visual_type", "caption", "is_legal_boundary"],
          "properties": {
            "visual_type": {
              "type": "string",
              "enum": ["exact_marker", "visual_plot_envelope", "satellite_highlight", "street_view", "not_available"]
            },
            "caption": { "type": "string" },
            "is_legal_boundary": { "type": "boolean" },
            "source_refs": { "$ref": "#/$defs/source_ref_array" }
          }
        },
        "not_claimed": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "multi_anchor_story": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/anchor_layer" }
    },
    "catchment_and_reach": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/catchment_view" }
    },
    "arrival_reality": {
      "$ref": "#/$defs/report_section"
    },
    "key_numbers": {
      "type": "array",
      "items": { "$ref": "#/$defs/key_number" }
    },
    "competition_and_pricing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "competitors", "pricing_normalization_note"],
      "properties": {
        "summary": { "type": "string" },
        "competitors": {
          "type": "array",
          "items": { "$ref": "#/$defs/competitor" }
        },
        "pricing_records": {
          "type": "array",
          "description": "Slot-level price observations from public booking surfaces. Only compare prices after duration and unit are normalized.",
          "items": { "$ref": "#/$defs/pricing_record" }
        },
        "pricing_normalization_note": { "type": "string" }
      }
    },
    "spend_and_convenience": {
      "$ref": "#/$defs/report_section"
    },
    "locality_conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/locality_condition" }
    },
    "visual_evidence_pack": {
      "type": "array",
      "items": { "$ref": "#/$defs/visual_item" }
    },
    "field_verification_plan": {
      "type": "array",
      "items": { "$ref": "#/$defs/field_check" }
    },
    "source_notes": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_note" }
    },
    "internal_data_quality": {
      "type": "object",
      "description": "Optional internal-only metadata for QA and retrieval. Do not expose as user-facing badges.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "source_ref_array": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reader_point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "text"],
      "properties": {
        "title": { "type": "string" },
        "text": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/source_ref_array" }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value", "unit"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": ["number", "integer", "string", "null"] },
        "unit": { "type": "string" },
        "radius_or_area": { "type": "string" },
        "time_window": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/source_ref_array" },
        "data_limit_note": { "type": "string" }
      }
    },
    "key_number": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value", "why_it_matters"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": ["number", "integer", "string", "null"] },
        "unit": { "type": "string" },
        "why_it_matters": { "type": "string" },
        "data_limit_note": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/source_ref_array" }
      }
    },
    "anchor_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer", "what_is_visible", "how_it_should_shape_the_view"],
      "properties": {
        "layer": {
          "type": "string",
          "enum": [
            "exact_pin",
            "adjacent_operators",
            "same_category_market",
            "audience_anchors",
            "access_friction",
            "spend_convenience",
            "locality_conditions",
            "field_verification"
          ]
        },
        "what_is_visible": { "type": "string" },
        "how_it_should_shape_the_view": { "type": "string" },
        "key_numbers": {
          "type": "array",
          "items": { "$ref": "#/$defs/metric" }
        },
        "source_refs": { "$ref": "#/$defs/source_ref_array" }
      }
    },
    "catchment_view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catchment", "character", "purpose_meaning"],
      "properties": {
        "catchment": { "type": "string" },
        "character": { "type": "string" },
        "purpose_meaning": { "type": "string" },
        "key_numbers": {
          "type": "array",
          "items": { "$ref": "#/$defs/metric" }
        },
        "data_limit_note": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/source_ref_array" }
      }
    },
    "report_section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "interpretation"],
      "properties": {
        "summary": { "type": "string" },
        "interpretation": {
          "type": "array",
          "items": { "type": "string" }
        },
        "key_numbers": {
          "type": "array",
          "items": { "$ref": "#/$defs/metric" }
        },
        "watchouts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "data_limit_note": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/source_ref_array" }
      }
    },
    "competitor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "observable_facts", "price_status", "use_in_report"],
      "properties": {
        "name": { "type": "string" },
        "distance_or_travel_time": { "type": "string" },
        "observable_facts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "price_status": {
          "type": "string",
          "enum": ["normalized", "visible_but_not_normalized", "not_available", "separate_event_or_coaching_price"]
        },
        "normalized_price": { "$ref": "#/$defs/metric" },
        "use_in_report": { "type": "string" },
        "data_limit_note": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/source_ref_array" }
      }
    },
    "pricing_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "venue_name", "sport_or_activity", "observed_at", "normalization_status"],
      "properties": {
        "platform": { "type": "string" },
        "venue_name": { "type": "string" },
        "sport_or_activity": { "type": "string" },
        "observed_at": { "type": "string" },
        "slot_duration_minutes": { "type": ["integer", "null"] },
        "display_price": { "type": ["number", "string", "null"] },
        "display_price_unit": {
          "type": "string",
          "enum": ["per_court", "per_person", "per_slot", "coaching_or_event", "not_clear", "not_available"]
        },
        "normalized_price_per_court_hour": { "type": ["number", "null"] },
        "normalization_status": {
          "type": "string",
          "enum": ["normalized", "visible_but_not_normalized", "not_available", "not_comparable"]
        },
        "normalization_note": { "type": "string" },
        "data_limit_note": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/source_ref_array" }
      }
    },
    "locality_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "what_can_be_used", "report_language"],
      "properties": {
        "condition": { "type": "string" },
        "what_can_be_used": { "type": "string" },
        "report_language": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/source_ref_array" }
      }
    },
    "visual_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "visual_type", "purpose", "caption"],
      "properties": {
        "title": { "type": "string" },
        "visual_type": {
          "type": "string",
          "enum": [
            "exact_pin_map",
            "satellite_highlight",
            "street_view",
            "catchment_map",
            "arrival_sequence",
            "competitor_map",
            "pricing_chart",
            "platform_screenshot",
            "field_photo_checklist"
          ]
        },
        "purpose": { "type": "string" },
        "caption": { "type": "string" },
        "data_limit_note": { "type": "string" },
        "source_refs": { "$ref": "#/$defs/source_ref_array" }
      }
    },
    "field_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visit_window", "what_to_check", "why_it_matters"],
      "properties": {
        "visit_window": { "type": "string" },
        "what_to_check": {
          "type": "array",
          "items": { "type": "string" }
        },
        "why_it_matters": { "type": "string" }
      }
    },
    "source_note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "source_type", "used_for", "user_facing_note"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "source_type": {
          "type": "string",
          "enum": [
            "official_public",
            "commercial_api",
            "open_map",
            "public_web_gold",
            "imagery",
            "field_observation",
            "user_supplied",
            "licensed_dataset"
          ]
        },
        "last_checked": { "type": "string" },
        "spatial_resolution": { "type": "string" },
        "pin_conditioned": { "type": "boolean" },
        "used_for": {
          "type": "array",
          "items": { "type": "string" }
        },
        "user_facing_note": { "type": "string" },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "internal_collection_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
